# muapi.ai API key for AI video generation (get one at https://muapi.ai)
MUAPI_KEY=

# Optional overrides
# MUAPI_BASE=https://api.muapi.ai
# Text→video model endpoint = a valid muapi model name (see full list:
#   curl https://api.muapi.ai/api/v1/models ). The pipeline calls
#   https://api.muapi.ai/api/v1/<MUAPI_VIDEO_ENDPOINT>
# Examples (name | approx cost):
#   pixverse-v5.5-t2v            | $0.10  (cheap, cinematic — good default)
#   hunyuan-fast-text-to-video   | $0.05  (fastest/cheapest)
#   minimax-hailuo-02-standard-t2v | $0.30
#   kling-v2.1-master-t2v        | $1.20  (top-tier realism)
# MUAPI_VIDEO_ENDPOINT=pixverse-v5.5-t2v

# ── Transactional email (сброс пароля + 6-значный код входа) ────────────────
# Полная инструкция (бесплатная почта info@/support@/sales@, DNS, провайдеры):
#   docs/EMAIL_SETUP.md
# Достаточно ОДНОГО ключа; при двух — автоматический failover.
#   Resend (https://resend.com)  — бесплатно 3 000 писем/мес
#   Brevo  (https://brevo.com)   — бесплатно 300 писем/день (~9 000/мес)
# Без ключей письма печатаются в консоль сервера (dev), а код при входе
# отключается — вход работает как раньше, по одному паролю.
# RESEND_API_KEY=
# BREVO_API_KEY=
# Обратный адрес отправителя (должен быть на подтверждённом домене провайдера):
# EMAIL_FROM=info@example.com
# EMAIL_FROM_NAME=Builder Studio
# EMAIL_REPLY_TO=support@example.com
# Какого провайдера пробовать первым: resend (по умолчанию) | brevo
# EMAIL_PROVIDER=resend
# Выключить email-код при входе, оставив только пароль:
# AUTH_EMAIL_OTP=off

# Публичные контакты в футере сайта (info@ / support@ / sales@) генерируются
# из домена АВТОМАТИЧЕСКИ. Обычно достаточно EMAIL_FROM (напр. info@acme.com) —
# тогда домен возьмётся оттуда. Эта переменная нужна только чтобы ЯВНО задать
# другой домен для контактов, не трогая EMAIL_FROM. На localhost/*.fly.dev блок
# контактов скрыт, пока не подключён настоящий домен.
# NEXT_PUBLIC_CONTACT_DOMAIN=acme.com

# Privacy-first analytics: Cloudflare Web Analytics beacon token (cookieless).
# Create a site at dash.cloudflare.com → Web Analytics and paste the token.
# Leave empty to disable analytics entirely.
NEXT_PUBLIC_CF_BEACON_TOKEN=

# ── Product analytics: PostHog (optional, free ~1M событий/мес) ──────────────
# Session replay, feature flags, A/B-тесты, autocapture. Гейтится ключом —
# без него ничего не грузится. Создать проект на app.posthog.com.
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # или https://eu.i.posthog.com

# ── Bot protection: Cloudflare Turnstile (optional, бесплатно) ──────────────
# Бесплатная приватная замена CAPTCHA для форм и логина. Без секрета проверка
# отключена (fail-open). dash.cloudflare.com → Turnstile → создать виджет.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...     # публичный ключ (виджет)
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...               # серверный секрет (проверка)

# ── Edge inference: Cloudflare Workers AI (optional, 10k нейронов/день) ──────
# Embeddings (семантический поиск) + лёгкий чат на edge. Токен с правом
# "Workers AI". CF_ACCOUNT_ID по умолчанию берётся из R2_ACCOUNT_ID.
# CF_ACCOUNT_ID=
# CF_AI_TOKEN=
# CF_AI_EMBED_MODEL=@cf/baai/bge-base-en-v1.5
# CF_AI_CHAT_MODEL=@cf/meta/llama-3.1-8b-instruct

# ── Error monitoring: Sentry (optional, free tier) ──────────────────────────
# Без SENTRY_DSN сборка и рантайм не меняются (SDK не инициализируется, конфиг
# не оборачивается). Создать проект на sentry.io → Next.js.
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX            # серверный DSN
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX # клиентский DSN
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Session Replay (0 = выкл; напр. 0.1 = 10% сессий, 1 = все сессии с ошибкой):
# NEXT_PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0
# NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1
# Загрузка source maps при сборке (нужны все три):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ── Object storage: Cloudflare R2 (optional) ────────────────────────────────
# When set, user uploads are stored in R2 and served from R2_PUBLIC_BASE_URL.
# Without them everything falls back to the local public/uploads folder.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=https://cdn.example.com   # public bucket URL or custom domain
#
# Static app media (tutorial videos/images and other /media assets) served from
# R2/CDN. Set this to the SAME public base (or a CDN in front of R2). Client-side
# code reads it, so it MUST be a NEXT_PUBLIC_ var. Leave empty to serve /media
# from the local public/ folder. Upload keeping the path, e.g.:
#   media/builder-tutorial.en.webm, media/tutorial-shot-1.jpg
# NEXT_PUBLIC_MEDIA_BASE_URL=https://cdn.example.com

# Keep an audio track on generated clips (enables the in-player sound toggle):
#   npm run media -- --prompt "..." --section hero --title "..." --audio

# Optional: LLM for auto-picking the theme AND generating page copy/blocks
# (any OpenAI-compatible /chat/completions endpoint — see lib/llm.ts). Without
# these, theme selection falls back to keyword matching and page generation to a
# deterministic template, so everything still works.
#
# Recommended FREE option — Groq (30 req/min, без карты):
#   THEME_LLM_URL=https://api.groq.com/openai/v1/chat/completions
#   THEME_LLM_KEY=gsk_...
#   THEME_LLM_MODEL=llama-3.3-70b-versatile
# Other drop-ins: OpenAI, OpenRouter, Together, muapi, local Ollama.
# (LLM_URL / LLM_KEY / LLM_MODEL тоже принимаются как алиасы.)
#   THEME_LLM_URL=https://api.muapi.ai/v1/chat/completions
#   THEME_LLM_KEY=your-openai-compatible-key
#   THEME_LLM_MODEL=gpt-4o-mini

# сгенерировать hero одним промптом:
  npm run media -- --prompt "Cinematic macro of brake discs, sparks, slow motion" \
    --section hero --title "Engineered to Stop" --cta "Shop now" --ctaHref "/products"

# ── Вход через Google (OAuth 2.0 / OpenID Connect) ──────────────────────────
# Серверный authorization-code flow (клиентский секрет НИКОГДА не попадает в
# браузер). Без этих переменных кнопка «Войти через Google» просто не
# показывается — email/пароль и Telegram работают как раньше.
#
# Как получить ключи:
#  1. https://console.cloud.google.com → создайте (или выберите) проект.
#  2. "APIs & Services" → "OAuth consent screen": тип External, заполните
#     название приложения, укажите свою почту, scopes оставьте базовые
#     (email, profile, openid). Опубликуйте (Publish) или добавьте себя в
#     Test users, пока приложение в тестовом режиме.
#  3. "APIs & Services" → "Credentials" → "Create Credentials" →
#     "OAuth client ID" → тип "Web application".
#  4. В "Authorized redirect URIs" добавьте ТОЧНО (для каждой среды):
#        http://localhost:3000/api/auth/google/callback      (локально)
#        https://<ваш-домен>/api/auth/google/callback         (прод)
#  5. Скопируйте Client ID и Client secret сюда.
# GOOGLE_CLIENT_ID=1234567890-xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# (принимаются также алиасы AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET — как в hr-project)
#
# Callback URL по умолчанию выводится из NEXT_PUBLIC_APP_HOST
# (напр. https://studio.acme.com/api/auth/google/callback). Задайте явно,
# только если нужен нестандартный адрес:
# GOOGLE_REDIRECT_URI=https://studio.acme.com/api/auth/google/callback
#
# Кто становится суперадмином при первом входе (через Google ИЛИ email),
# comma-separated. Если такой email уже есть (создан по паролю/Telegram),
# Google-вход ПРИВЯЗЫВАЕТСЯ к тому же аккаунту — суперадмин остаётся ОДИН.
# SUPERADMIN_EMAILS=owner@example.com

# Аналогично для Telegram: @username(ы), которые становятся суперадмином.
# SUPERADMIN_TELEGRAM=owner

# ── Публичный адрес и поддомены сайтов ──────────────────────────────────────
# NEXT_PUBLIC_APP_HOST — основной домен платформы (без http/https, без слэша).
# Из него формируются адреса сайтов клиентов:
#   • путь (всегда работает):  <host>/s/<slug>
#   • поддомен (красивый URL):  <slug>.<host>   — ТОЛЬКО на своём апекс-домене
#   • кастомный домен:          подключается в настройках сайта (Pro/Studio)
# NEXT_PUBLIC_APP_HOST=builder-studio.com
#
# ВАЖНО про поддомены:
#   • На управляемых хостах (*.fly.dev, *.vercel.app, *.onrender.com, …) и на
#     localhost поддомены сайтов НЕ работают — там платформа отвечает только на
#     точный хост. Приложение это определяет автоматически и показывает
#     рабочий адрес вида <host>/s/<slug>.
#   • Чтобы включить настоящие поддомены, нужен СВОЙ апекс-домен
#     (напр. builder-studio.com) + DNS wildcard  *.builder-studio.com  → хост,
#     и wildcard-TLS (*.builder-studio.com). Тогда адреса станут <slug>.домен.
#   • Принудительно вкл/выкл (если авто-детект не подходит):
# NEXT_PUBLIC_TENANT_SUBDOMAINS=1

# ── Автоподключение кастомных доменов tenants ──────────────────────────────
# UX для админа: он только вставляет домен в dashboard и нажимает «Привязать».
# Всё техническое делает платформа, если superadmin заранее настроил провайдеры.
#
# 1) Хостинг/TLS на Fly.io: приложение само добавляет hostname и запускает
#    выпуск сертификата (аналог `fly certs add <domain>`).
# FLY_API_TOKEN=
# FLY_APP_NAME=builder-studio
#
# 2) DNS через Cloudflare: если домен/zone уже делегирован в Cloudflare аккаунт
#    платформы, приложение само создаёт/обновляет CNAME на платформенный host.
# CLOUDFLARE_API_TOKEN=
# CUSTOM_DOMAIN_CNAME_TARGET=builder-studio.fly.dev
#
# Важно: если домен куплен у стороннего регистратора и его DNS НЕ делегирован
# платформе, полностью автоматизировать DNS невозможно — superadmin должен
# сначала взять домен под управление платформенного DNS.

# ── Вход через Apple (Sign in with Apple, OAuth 2.0 / OIDC) ──────────────────
# Требует платный Apple Developer account. Настройка:
#  1. developer.apple.com → Certificates, IDs & Profiles.
#  2. Identifiers → создайте App ID, затем "Services ID" (это и есть
#     APPLE_CLIENT_ID, напр. com.acme.web) с включённым "Sign in with Apple".
#  3. В настройках Services ID → Web Authentication Configuration добавьте домен
#     и Return URL (ТОЧНО):
#        https://<ваш-домен>/api/auth/apple/callback
#     (Apple НЕ разрешает http/localhost — тестируйте на https-домене.)
#  4. Keys → создайте ключ с "Sign in with Apple", скачайте .p8 (это
#     APPLE_PRIVATE_KEY), запомните Key ID (APPLE_KEY_ID) и Team ID (APPLE_TEAM_ID).
# APPLE_CLIENT_ID=com.acme.web
# APPLE_TEAM_ID=ABCDE12345
# APPLE_KEY_ID=XYZ9876543
# Содержимое .p8 одной строкой с \n вместо переносов, ИЛИ многострочно в кавычках:
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"
# Callback по умолчанию выводится из NEXT_PUBLIC_APP_HOST; переопределить:
# APPLE_REDIRECT_URI=https://app.example.com/api/auth/apple/callback

# ── Billing (platform subscriptions + tenant member plans) ──────────────────
# Optional. With NO Stripe key the billing system runs in "manual" mode:
# checkout hands off to an internal confirm page, subscriptions/invoices are
# recorded locally, and the superadmin can grant plans by hand — so the whole
# flow (pricing → checkout → dashboards → PDF invoices) works with zero config.
#
# To take real card payments, set the PLATFORM Stripe secret + webhook signing
# secret. Organization admins create member plans, but they do NOT connect their
# own Stripe accounts; member payments are collected on the platform Stripe and
# shown to the superadmin in /dashboard/revenue for payout tracking.
#   STRIPE_SECRET_KEY=sk_live_or_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...     # from the Stripe webhook endpoint
# Platform fee percent deducted from collected member revenue before payouts:
#   PLATFORM_FEE_PERCENT=10
# Point the Stripe webhook at:  https://<your-host>/api/billing/webhook
# Subscribe to: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.paid, invoice.payment_failed
# NEXT_PUBLIC_APP_HOST must be set for correct success/cancel redirect URLs.
